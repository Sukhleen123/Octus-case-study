# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Vectorstore ───────────────────────────────────────────────────────────────
# vectorstore_provider: "auto" (Pinecone if key set, else FAISS) | "pinecone" | "faiss"
VECTORSTORE_PROVIDER=pinecone

